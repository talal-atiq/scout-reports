# Local MongoDB example:
# MONGODB_URL=mongodb://localhost:27017
# MongoDB Atlas example (replace credentials and cluster host):
# MONGODB_URL=mongodb+srv://<username>:<password>@<cluster-host>/?retryWrites=true&w=majority&appName=StatScout
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=statscout_db
SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=StatScout
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=["http://localhost:5173"]
DEBUG=true
API_V1_PREFIX=/api/v1
ADMIN_API_KEY=
